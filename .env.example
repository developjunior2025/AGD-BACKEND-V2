NODE_ENV=development
PORT=3000
API_PREFIX=api
CORS_ORIGIN=*

DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=agd
DB_PASSWORD=agd
DB_DATABASE=agd_backend
DB_SYNCHRONIZE=false
DB_LOGGING=false

JWT_ACCESS_SECRET=change-me-access-secret-min-16-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret-min-16-chars
JWT_REFRESH_EXPIRES_IN=7d

AUTH_FAILED_LOGIN_LOCK_THRESHOLD=5
AUTH_ACCOUNT_LOCK_MINUTES=15
AUTH_PASSWORD_RESET_TOKEN_MINUTES=30
